DB_HOST=localhost
DB_PORT=5432
DB_NAME=immich
DB_USER=postgres
DB_PASSWORD=postgres

IMMICH_URL=https://immich.example.com/api
IMMICH_API_KEY=your-immich-api-key

# Immich machine-learning service, required for smart search with text
# queries (it embeds the query text with CLIP). Usually port 3003 on the
# Immich host, internal to the docker network unless exposed.
MACHINE_LEARNING_URL=http://immich-machine-learning:3003
# Override the CLIP model name; defaults to the model configured in Immich
# (read from system_metadata), falling back to ViT-B-32__openai.
#CLIP_MODEL_NAME=

# Media path translation for reading EXIF with exiftool.
# Immich stores each asset's path as seen inside the Immich container
# (asset.originalPath). Before exiftool runs, Blacksmith strips SOURCE (if set)
# from that path, then prepends TARGET.
#   - Leave both empty: media is mounted at the identical path (no change).
#   - SOURCE empty, TARGET set: the whole Immich path is appended to TARGET.
#       e.g. TARGET=/Volumes turns /photos-archive/a.jpg into /Volumes/photos-archive/a.jpg
#   - Both set: the SOURCE prefix is swapped for TARGET.
#       e.g. SOURCE=/usr/src/app/upload TARGET=/media → /usr/src/app/upload/x → /media/x
MEDIA_PATH_SOURCE=
MEDIA_PATH_TARGET=

# ComfyUI image generation (/api/comfyui/generate). Only COMFYUI_URL is required.
COMFYUI_URL=http://comfyui:8188
# Directory of API-format workflow JSON templates. A request's `workflow` param
# selects <name>.json. Templates use the
# placeholders %%PROMPT%%, %%IMAGE%% (img2img only) and %%SEED%%.
COMFYUI_WORKFLOWS_DIR=./comfy-workflows

# Album that generated assets are added to (created if missing).
#COMFYUI_ALBUM_NAME=AI Generated
# Overall workflow timeout and history poll interval, in milliseconds.
#COMFYUI_TIMEOUT_MS=600000
#COMFYUI_POLL_INTERVAL_MS=2500
